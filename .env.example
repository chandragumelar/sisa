# Supabase — isi dari Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# VAPID public key untuk Web Push — generate dengan: npx web-push generate-vapid-keys
# Private key TIDAK masuk ke sini, hanya di server (edge function / cron)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
